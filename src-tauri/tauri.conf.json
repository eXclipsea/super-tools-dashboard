{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Super Tools",
  "version": "0.1.0",
  "identifier": "com.exclusipsea.supertools",
  "build": {
    "frontendDist": "https://super-tools-dashboard.vercel.app",
    "devUrl": "http://localhost:3006",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Super Tools",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' blob: data:; media-src 'self' blob:; connect-src 'self' https://api.openai.com https://api.groq.com https://api.anthropic.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
